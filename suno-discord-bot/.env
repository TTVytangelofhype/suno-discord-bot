# Discord Developer Portal values
DISCORD_TOKEN=your discord bot token
CLIENT_ID=bot client id
GUILD_ID=bot guild id
DISABLE_IPV6=true

# Bot branding
BOT_NAME=Nexus Suno Bot
BOT_ACCENT=FF6A00
BOT_FOOTER=Only Suno music allowed • Nexus Suno Bot

# Lock bot to one Discord server only
LOCK_TO_GUILD=true

# Suno-only controls
ALLOW_UPLOADS=false
ALLOW_DIRECT_MP3=true
MAX_QUEUE_SIZE=50
MAX_TRACK_SECONDS=600

# DJ role control. Use role names separated by commas.
DJ_ROLE_NAMES=DJ,Radio DJ,Staff,Admin

# 24/7 behaviour
LEAVE_WHEN_EMPTY=true
EMPTY_LEAVE_SECONDS=60

# Optional: keep web dashboard disabled unless you build your own front end
WEB_DASHBOARD=false
PORT=3000

LAVALINK_HOST=127.0.0.1
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass
